# Leave unset on Cloudflare Pages when using the included same-origin functions.
# Set this for purely static hosts that use an external feed aggregation endpoint.
# VITE_FEED_API_URL=https://your-proxy.example.com/api/feed

# Set this for purely static hosts that need an external Lobsters discussion proxy.
# VITE_API_PROXY_URL=https://your-proxy.example.com/api/lobsters
